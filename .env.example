# Léo frontend env (copy to .env.local and fill in)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
LEO_API_URL=http://localhost:8000
# Secret used to HMAC-sign the session cookie. Set a long random value in prod.
# Falls back to SUPABASE_SERVICE_ROLE_KEY if unset.
SESSION_SECRET=change-me-to-a-long-random-string
# Optional demo login (used only when Supabase is not configured)
# DEMO_EMAIL=
# DEMO_PASSWORD=


